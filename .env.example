# WebDAV Configuration
# Copy this file to .env.local and fill in your credentials

# WebDAV Server URL (e.g., https://cloud.your-provider.com/remote.php/dav/files/username/)
WEBDAV_URL=

# WebDAV Username
WEBDAV_USERNAME=

# WebDAV Password (use app password if available)
WEBDAV_PASSWORD=

# Photos directory path on WebDAV server (relative to root)
# Example: /Photos or /Images/MyPhotos
PHOTOS_DIR=/Photos
