{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
      "deny": [
        "Read(./.env)",
        "Read(./.env.*)",
        "Read(./secrets/**)",
        "Read(./*.key)",
        "Read(./*.pem)",
        "Read(./*.p12)",
        "Read(./.aws/credentials)",
        "Bash(curl * | bash)",
        "Bash(wget * | sh)",
        "Bash(git push --force*)",
        "Bash(git reset --hard*)",
        "Bash(chmod 777 *)",
        "Bash(chmod a+rwx *)",
        "Bash(rm -rf /*)",
        "Bash(docker system prune*)"
      ],
      "ask": [
        "Bash(git push*)",
        "Bash(git rebase*)",
        "Bash(npm install*)",
        "Bash(pip install*)",
        "Bash(kubectl delete*)",
        "Bash(kubectl apply*)",
        "Bash(helm upgrade*)",
        "Bash(helm uninstall*)",
        "Bash(terraform apply*)",
        "Bash(terraform destroy*)"
      ]
    }
  }